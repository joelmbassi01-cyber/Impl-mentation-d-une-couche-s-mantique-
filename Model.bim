        "partitions": [
          {
            "name": "FactSalesQuota",
            "dataView": "full",
            "source": {
              "type": "query",
              "query": " \t\t\t\tSELECT [dbo].[FactSalesQuota].*   FROM [dbo].[FactSalesQuota] ",
              "dataSource": "SqlServer KAIZER AdventureWorksDW2019"
            }
          }
        ],
        "measures": [
          {
            "name": "Somme de SalesAmountQuota",
            "expression": "SUM([SalesAmountQuota])",
            "formatString": "#,0.00 \"€\";-#,0.00 \"€\";#,0.00 \"€\"",
            "annotations": [
              {
                "name": "Format",
                "value": "<Format Format=\"Currency\" Accuracy=\"2\" ThousandSeparator=\"True\"><Currency LCID=\"1036\" DisplayName=\"€ Français (France)\" Symbol=\"€\" PositivePattern=\"3\" NegativePattern=\"8\" /></Format>"
              }
            ]
          },
          {
            "name": "Sales vs Quota",
            "expression": [
              "",
              "[Reseller Revenue] - [Somme de SalesAmountQuota]"
            ]
          },
          {
            "name": "Quota Achievement %",
            "expression": [
              "",
              "DIVIDE(",
              "    [Reseller Revenue],",
              "    [Somme de SalesAmountQuota]",
              ")"
            ],
            "kpi": {
              "targetExpression": "1",
              "statusGraphic": "Traffic Light - Single",
              "statusExpression": [
                "var x='FactSalesQuota'[Quota Achievement %] return",
                "            if(ISBLANK(x),BLANK(),",
                "                    If(x<0.8,-1,",
                "\t                If(x<1,0,1)",
                "                )",
                "            )",
                "            "
              ],
              "annotations": [
                {
                  "name": "GoalType",
                  "value": "StaticValue"
                },
                {
                  "name": "KpiStatusType",
                  "value": "Linear"
                },
                {
                  "name": "KpiThresholdType",
                  "value": "Absolute"
                },
                {
                  "name": "KpiThresholdOrdering",
                  "value": "Ascending"
                },
                {
                  "name": "KpiThresholdCount",
                  "value": "2"
                },
                {
                  "name": "KpiThreshold_0",
                  "value": "0.8"
                },
                {
                  "name": "KpiThreshold_1",
                  "value": "1"
                }
              ]
            }
          }
        ],
        "annotations": [
          {
            "name": "_TM_ExtProp_QueryDefinition",
            "value": " \t\t\t\tSELECT [dbo].[FactSalesQuota].*   FROM [dbo].[FactSalesQuota] "
