        "partitions": [
          {
            "name": "FactResellerSales",
            "dataView": "full",
            "source": {
              "type": "query",
              "query": " \t\t\t\tSELECT [dbo].[FactResellerSales].*   FROM [dbo].[FactResellerSales] ",
              "dataSource": "SqlServer KAIZER AdventureWorksDW2019"
            }
          }
        ],
        "measures": [
          {
            "name": "Reseller Revenue",
            "expression": " SUM(FactResellerSales[SalesAmount])"
          },
          {
            "name": "Reseller Cost",
            "expression": " SUM(FactResellerSales[TotalProductCost])"
          },
          {
            "name": "Reseller Net Profit",
            "expression": [
              "",
              "[Reseller Revenue] - [Reseller Cost] -[Reseller Freight]"
            ]
          },
          {
            "name": "Reseller Freight",
            "expression": " SUM(FactResellerSales[Freight])"
          },
          {
            "name": "Reseller Profit",
            "expression": [
              "",
              "[Reseller Revenue] - [Reseller Cost]"
            ]
          }
        ],
        "annotations": [
          {
            "name": "_TM_ExtProp_QueryDefinition",
            "value": " \t\t\t\tSELECT [dbo].[FactResellerSales].*   FROM [dbo].[FactResellerSales] "
